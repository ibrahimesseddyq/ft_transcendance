// =============================================
// HIRING PLATFORM - QUIZ SERVICE (LIBRARY MODE)
// Test Library + Evaluation Engine
// NO submission tracking - main_service handles that
// Database: MySQL 8.0+
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===================
// ENUMS
// ===================

enum TestType {
  QUIZ
  CODE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ===================
// ONLY 1 TABLE - TEST LIBRARY
// ===================

model Test {
  id          String   @id @default(uuid()) @db.Char(36)
  type        TestType
  title       String   @db.VarChar(255)
  description String?  @db.Text

  // All test content stored as JSON
  content Json
  /**
   * Structure:
   * {
   * "durationMinutes": 30,
   * "passingScore": 70,
   * "items": [
   * // FOR QUIZ TYPE:
   * {
   * "id": "q1",
   * "question": "What is a closure in JavaScript?",
   * "choices": [
   * {"id": "A", "text": "A way to close files", "isCorrect": false},
   * {"id": "B", "text": "Function with lexical scope access", "isCorrect": true},
   * {"id": "C", "text": "A loop structure", "isCorrect": false},
   * {"id": "D", "text": "An error handler", "isCorrect": false}
   * ],
   * "points": 1,
   * "explanation": "Optional explanation for learning"
   * },
   * // FOR CODE TYPE:
   * {
   * "id": "c1",
   * "title": "Two Sum Problem",
   * "description": "Given an array of integers nums and an integer target...",
   * "starterCode": "function twoSum(nums, target) {\n  // Your code here\n}",
   * "language": "javascript",
   * "testCases": [
   * {
   * "input": "[2,7,11,15]\n9",
   * "expectedOutput": "[0,1]",
   * "isHidden": false,
   * "points": 3
   * },
   * {
   * "input": "[3,2,4]\n6",
   * "expectedOutput": "[1,2]",
   * "isHidden": false,
   * "points": 3
   * },
   * {
   * "input": "[1000 numbers...]\n500",
   * "expectedOutput": "[234,567]",
   * "isHidden": true,
   * "points": 4
   * }
   * ],
   * "timeLimit": 5000,
   * "memoryLimit": 128000,
   * "points": 10,
   * "hints": ["Think about hash maps", "O(n) time complexity"]
   * }
   * ]
   * }
   */

  // Library metadata for browsing/filtering
  category   String?     @db.VarChar(100) // "JavaScript", "Algorithms", "System Design"
  difficulty Difficulty?
  tags       Json? // ["frontend", "react", "hooks", "es6"]

  // Publishing control
  isPublished Boolean @default(false) // Only published tests shown in library
  version     Int     @default(1) // For versioning tests

  // Ownership
  createdBy String   @db.Char(36) // → main_service.users (recruiter/admin)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isPublished])
  @@index([category])
  @@index([difficulty])
  @@index([createdBy])
}

// ===================
// NOTES
// ===================

// NO Submission table - main_service stores submissions
// NO Answer table - main_service stores answers
// NO CodeExecution table - evaluation is stateless

// This service is PURE:
// - Input: Test content
// - Output: Evaluation result
// - No state management
// - No application tracking
