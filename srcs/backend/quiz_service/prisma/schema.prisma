// =============================================
// HIRING PLATFORM - QUIZ SERVICE (SEPARATED)
// Handles: Quiz Tests & Code Tests as separate entities
// Database: MySQL 8.0+
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===================
// ENUMS
// ===================

enum SubmissionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  TIMEOUT
}

// ===================
// QUIZ TEST (MCQ)
// ===================

model QuizTest {
  id               String   @id @default(uuid()) @db.Char(36)
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  durationMinutes  Int      
  passingScore     Int      @default(60) // Percentage (0-100)
  createdBy        String   @db.Char(36) // Foreign key to main_service.users
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  questions        QuizQuestion[]
  submissions      QuizSubmission[]

  @@index([createdBy])
}

// ===================
// QUIZ QUESTIONS
// ===================

model QuizQuestion {
  id         String   @id @default(uuid()) @db.Char(36)
  quizTestId String   @db.Char(36)
  question   String   @db.Text
  choices    Json     // Array of exactly 4 choices: [{id: string, text: string, isCorrect: boolean}]
  points     Int      @default(1)
  order      Int      

  // Relations
  quizTest   QuizTest     @relation(fields: [quizTestId], references: [id], onDelete: Cascade)
  answers    QuizAnswer[]

  @@index([quizTestId])
  @@index([quizTestId, order])
}

// ===================
// QUIZ SUBMISSION
// ===================

model QuizSubmission {
  id                 String    @id @default(uuid()) @db.Char(36)
  applicationPhaseId String    @db.Char(36) // Foreign key to main_service.application_phases
  candidateId        String    @db.Char(36) // Foreign key to main_service.users
  quizTestId         String    @db.Char(36)
  
  startedAt          DateTime  @default(now())
  submittedAt        DateTime? 
  
  score              Int?      // Total score achieved
  maxScore           Int?      // Total possible score
  passed             Boolean?  // Computed based on passingScore
  timeSpent          Int?      // Seconds
  
  // Relations
  quizTest           QuizTest     @relation(fields: [quizTestId], references: [id])
  answers            QuizAnswer[]

  @@index([quizTestId])
  @@index([candidateId])
  @@index([applicationPhaseId])
  @@unique([applicationPhaseId, quizTestId]) // One submission per quiz test per phase
}

// ===================
// QUIZ ANSWERS
// ===================

model QuizAnswer {
  id               String    @id @default(uuid()) @db.Char(36)
  submissionId     String    @db.Char(36)
  questionId       String    @db.Char(36)
  selectedChoiceId String?   @db.VarChar(50) // ID from the choices JSON array
  isCorrect        Boolean?  
  answeredAt       DateTime  @default(now())

  // Relations
  submission QuizSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   QuizQuestion   @relation(fields: [questionId], references: [id])

  @@index([submissionId])
  @@index([questionId])
  @@unique([submissionId, questionId]) // One answer per question per submission
}

// ===================
// CODE TEST
// ===================

model CodeTest {
  id               String   @id @default(uuid()) @db.Char(36)
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  durationMinutes  Int      
  passingScore     Int      @default(60) // Percentage (0-100)
  createdBy        String   @db.Char(36) // Foreign key to main_service.users
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  challenges       CodeChallenge[]
  submissions      CodeSubmission[]

  @@index([createdBy])
}

// ===================
// CODE CHALLENGES
// ===================

model CodeChallenge {
  id              String   @id @default(uuid()) @db.Char(36)
  codeTestId      String   @db.Char(36)
  title           String   @db.VarChar(255)
  description     String   @db.Text
  starterCode     String?  @db.Text // Template code for Monaco editor
  language        String   @db.VarChar(50) // e.g., "javascript", "python", "java"
  testCases       Json     // [{input: string, expectedOutput: string, isHidden: boolean, points: number}]
  points          Int      @default(10)
  timeLimit       Int      @default(5000) // milliseconds for Judge0
  memoryLimit     Int      @default(128000) // KB for Judge0
  order           Int      
  
  // Relations
  codeTest        CodeTest           @relation(fields: [codeTestId], references: [id], onDelete: Cascade)
  solutions       CodeSolution[]

  @@index([codeTestId])
  @@index([codeTestId, order])
}

// ===================
// CODE SUBMISSION
// ===================

model CodeSubmission {
  id                 String    @id @default(uuid()) @db.Char(36)
  applicationPhaseId String    @db.Char(36) // Foreign key to main_service.application_phases
  candidateId        String    @db.Char(36) // Foreign key to main_service.users
  codeTestId         String    @db.Char(36)
  
  startedAt          DateTime  @default(now())
  submittedAt        DateTime? 
  
  score              Int?      // Total score achieved
  maxScore           Int?      // Total possible score
  passed             Boolean?  // Computed based on passingScore
  timeSpent          Int?      // Seconds
  
  // Relations
  codeTest           CodeTest       @relation(fields: [codeTestId], references: [id])
  solutions          CodeSolution[]

  @@index([codeTestId])
  @@index([candidateId])
  @@index([applicationPhaseId])
  @@unique([applicationPhaseId, codeTestId]) // One submission per code test per phase
}

// ===================
// CODE SOLUTIONS (Judge0 Integration)
// ===================

model CodeSolution {
  id                String             @id @default(uuid()) @db.Char(36)
  submissionId      String             @db.Char(36)
  challengeId       String             @db.Char(36)
  
  // Submission data
  code              String             @db.Text
  language          String             @db.VarChar(50)
  
  // Judge0 integration
  judge0Token       String?            @db.VarChar(255) // Token from Judge0 API
  status            SubmissionStatus   @default(PENDING)
  
  // Execution results
  executionTime     Int?               // Milliseconds
  memoryUsed        Int?               // Kilobytes
  testResults       Json?              // [{caseId: number, passed: boolean, output: string, error?: string}]
  passedCount       Int?               // Number of test cases passed
  totalCount        Int?               // Total number of test cases
  score             Int?               // Points earned
  
  // Error handling
  error             String?            @db.Text
  
  // Timestamps
  submittedAt       DateTime           @default(now())
  completedAt       DateTime?          

  // Relations
  submission CodeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  challenge  CodeChallenge  @relation(fields: [challengeId], references: [id])

  @@index([submissionId])
  @@index([challengeId])
  @@index([judge0Token])
  @@index([status])
  @@unique([submissionId, challengeId]) // One solution per challenge per submission
}
