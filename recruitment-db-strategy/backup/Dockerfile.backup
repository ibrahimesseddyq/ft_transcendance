# ============================================================================
# Dockerfile for MySQL Backup Service
# ============================================================================

FROM ubuntu:22.04

# Install dependencies
RUN apt-get update && apt-get install -y \
    mysql-client \
    cron \
    gzip \
    curl \
    awscli \
    mailutils \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create directories
RUN mkdir -p /var/backups/mysql/{daily,weekly,monthly} \
    && mkdir -p /var/log/mysql-backup \
    && mkdir -p /scripts \
    && mkdir -p /etc/mysql

# Copy scripts
COPY backup.sh /scripts/backup.sh
COPY restore.sh /scripts/restore.sh
RUN chmod +x /scripts/*.sh

# Create backup MySQL config
RUN echo "[client]\nuser=backup_user\npassword=\${MYSQL_BACKUP_PASSWORD}" > /etc/mysql/backup.cnf \
    && chmod 600 /etc/mysql/backup.cnf

# Setup cron jobs
COPY crontab /etc/cron.d/backup-cron
RUN chmod 0644 /etc/cron.d/backup-cron \
    && crontab /etc/cron.d/backup-cron

# Create log file
RUN touch /var/log/cron.log

# Entry point script
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["cron", "-f"]
