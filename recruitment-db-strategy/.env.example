# ============================================================================
# Environment Configuration
# Recruitment Platform - Backup & Archive System
# ============================================================================

# ----------------------------------------------------------------------------
# MySQL Credentials
# ----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_BACKUP_USER=backup_user
MYSQL_BACKUP_PASSWORD=your_secure_backup_password_here
MYSQL_EXPORTER_PASSWORD=your_exporter_password_here

# ----------------------------------------------------------------------------
# Remote Storage (S3/MinIO)
# ----------------------------------------------------------------------------
REMOTE_STORAGE_ENABLED=true
S3_BUCKET=recruitment-backups
S3_PATH=mysql

# For AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# For MinIO (local S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password

# ----------------------------------------------------------------------------
# Notifications
# ----------------------------------------------------------------------------
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
EMAIL_RECIPIENT=admin@yourcompany.com

# ----------------------------------------------------------------------------
# Retention Settings (in days)
# ----------------------------------------------------------------------------
RETENTION_DAYS_DAILY=7
RETENTION_DAYS_WEEKLY=30
RETENTION_DAYS_MONTHLY=365

# ----------------------------------------------------------------------------
# Archive Settings
# ----------------------------------------------------------------------------
ARCHIVE_APPLICATIONS_AFTER_MONTHS=6
ARCHIVE_NOTIFICATIONS_AFTER_DAYS=90
ARCHIVE_INTERVIEWS_AFTER_MONTHS=6
ARCHIVE_RETENTION_YEARS=2
