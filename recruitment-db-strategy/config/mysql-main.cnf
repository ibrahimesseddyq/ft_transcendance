# ============================================================================
# MySQL Configuration - Main Database
# Optimized for OLTP workloads
# ============================================================================

[mysqld]
# ----------------------------------------------------------------------------
# General Settings
# ----------------------------------------------------------------------------
default-storage-engine          = InnoDB
character-set-server            = utf8mb4
collation-server                = utf8mb4_unicode_ci
max_connections                 = 200
wait_timeout                    = 28800
interactive_timeout             = 28800

# ----------------------------------------------------------------------------
# Binary Logging (Required for Point-in-Time Recovery)
# ----------------------------------------------------------------------------
server-id                       = 1
log_bin                         = mysql-bin
binlog_format                   = ROW
binlog_expire_logs_seconds      = 604800  # 7 days
max_binlog_size                 = 100M
sync_binlog                     = 1

# Enable GTID for easier replication management
gtid_mode                       = ON
enforce_gtid_consistency        = ON

# ----------------------------------------------------------------------------
# InnoDB Settings
# ----------------------------------------------------------------------------
innodb_buffer_pool_size         = 1G      # Adjust based on available RAM (50-70%)
innodb_buffer_pool_instances    = 4
innodb_log_file_size            = 256M
innodb_log_buffer_size          = 16M
innodb_flush_log_at_trx_commit  = 1       # Full ACID compliance
innodb_flush_method             = O_DIRECT
innodb_file_per_table           = ON

# ----------------------------------------------------------------------------
# Query Cache (Disabled in MySQL 8.0+)
# ----------------------------------------------------------------------------
# query_cache_type              = 0
# query_cache_size              = 0

# ----------------------------------------------------------------------------
# Slow Query Log
# ----------------------------------------------------------------------------
slow_query_log                  = ON
slow_query_log_file             = /var/log/mysql/slow-query.log
long_query_time                 = 2
log_queries_not_using_indexes   = ON

# ----------------------------------------------------------------------------
# Error Log
# ----------------------------------------------------------------------------
log_error                       = /var/log/mysql/error.log

# ----------------------------------------------------------------------------
# Event Scheduler (Required for automated archiving)
# ----------------------------------------------------------------------------
event_scheduler                 = ON

# ----------------------------------------------------------------------------
# Performance Schema
# ----------------------------------------------------------------------------
performance_schema              = ON

[client]
default-character-set           = utf8mb4
